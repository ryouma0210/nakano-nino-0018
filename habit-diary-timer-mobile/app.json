{
  "expo": {
    "name": "Nino Room",
    "slug": "habit-diary-timer-mobile",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "habitdiarytimer",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications",
      "expo-video",
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "ご褒美動画を表示するため、写真と動画へのアクセスを使用します。",
          "savePhotosPermission": "ご褒美動画を端末へ保存するため、写真と動画への保存を使用します。"
        }
      ],
      "expo-image"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "jp.local.habitdiarytimer"
    },
    "android": {
      "package": "jp.local.habitdiarytimer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#050505"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "local-only"
      }
    }
  }
}

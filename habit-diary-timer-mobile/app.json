{
  "expo": {
    "name": "Nino Room",
    "slug": "habit-diary-timer-mobile",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "habitdiarytimer",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications",
      "expo-video"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "jp.local.habitdiarytimer"
    },
    "android": {
      "package": "jp.local.habitdiarytimer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#050505"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "local-only"
      }
    }
  }
}

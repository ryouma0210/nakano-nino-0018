    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "babel-preset-expo": "^57.0.3",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3"

{
  "name": "habit-diary-timer-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "sync:shared": "node scripts/sync-shared.cjs",
    "prestart": "npm run sync:shared",
    "start": "expo start",
    "pretunnel": "npm run sync:shared",
    "tunnel": "expo start -c --tunnel",
    "preandroid": "npm run sync:shared",
    "android": "expo start --android",
    "preios": "npm run sync:shared",
    "ios": "expo start --ios",
    "preweb": "npm run sync:shared",
    "web": "expo start --web",
    "pretypecheck": "npm run sync:shared",
    "typecheck": "tsc --noEmit",
    "prelint": "npm run sync:shared",
    "lint": "eslint . --ext .ts,.tsx",
    "build:android-apk": "eas build -p android --profile preview",
    "build:ios-testflight": "eas build -p ios --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@hookform/resolvers": "^5.2.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~57.0.6",
    "expo-asset": "~57.0.6",
    "expo-audio": "~57.0.1",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "^57.0.5",
    "expo-document-picker": "^57.0.1",
    "expo-file-system": "^57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "^57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-media-library": "~57.0.3",
    "expo-notifications": "^57.0.5",
    "expo-router": "^57.0.6",
    "expo-sharing": "^57.0.5",
    "expo-sqlite": "^57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-video": "~57.0.1",
    "react": "19.2.3",
    "react-hook-form": "^7.61.1",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^2.29.1",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
